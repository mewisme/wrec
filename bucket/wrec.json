{
  "version": "0.2.2",
  "description": "Record one or more Windows windows into a single MP4",
  "homepage": "https://github.com/mewisme/wrec",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/mewisme/wrec/releases/download/v0.2.2/wrec-v0.2.2-windows-amd64.zip",
      "hash": "8662FC1DF36410683750B04F10C2A42E9B847C68D2949263D3914C641B7B5F48"
    }
  },
  "bin": "wrec.exe",
  "post_install": [
    "$wsh = New-Object -ComObject WScript.Shell",
    "foreach ($folder in @([Environment]::GetFolderPath('Desktop'), [Environment]::GetFolderPath('Programs'))) {",
    "  $lnk = $wsh.CreateShortcut(\"$folder\\wrec.lnk\")",
    "  $lnk.TargetPath = \"$dir\\wrec.exe\"",
    "  $lnk.WorkingDirectory = \"$dir\"",
    "  $lnk.Description = 'wrec'",
    "  $lnk.Save()",
    "}"
  ],
  "pre_uninstall": [
    "foreach ($folder in @([Environment]::GetFolderPath('Desktop'), [Environment]::GetFolderPath('Programs'))) {",
    "  Remove-Item \"$folder\\wrec.lnk\" -Force -ErrorAction SilentlyContinue",
    "}"
  ],
  "checkver": {
    "github": "mewisme/wrec"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/mewisme/wrec/releases/download/v0.2.2/wrec-v$version-windows-amd64.zip"
      }
    }
  }
}
